<?xml version='1.0' encoding='UTF-8'?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="screw_hinge_module_dynamixel">
  <xacro:macro name="screw_hinge_module_dynamixel" params="prefix:='' parent_link:=world xyz:='0 0 0' rpy:='0 0 0' package_name:=gimbalrotor">
    <joint name="${parent_link}_to_${prefix}base_link_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="-0.000125522807867996 6.25397854935558e-05 0.0152522387170004" rpy="0.0 -0.0 0.0"/>
        <mass value="0.0138575446641172"/>
        <inertia ixx="3.55557358743012e-06" ixy="6.50933428796727e-10" ixz="4.46136622179202e-08" iyy="6.32031958633877e-06" iyz="-1.9253050825893e-08" izz="4.57885870672051e-06"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://${package_name}/urdf/grape/meshes/arm/screw_hinge_module_dynamixel/base_link.dae"/>
        </geometry>
        <material name="${prefix}__unnamed_material_1"/>
        <origin xyz="0.0 0.0 0.0" rpy="1.5707963267949003 -2.99239799605999e-16 -1.5707963267949003"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://${package_name}/urdf/grape/meshes/arm/screw_hinge_module_dynamixel/base_link.stl"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="1.5707963267949003 -2.99239799605999e-16 -1.5707963267949003"/>
      </collision>
    </link>
    <link name="${prefix}link1">
      <inertial>
        <origin xyz="0.000338644241900288 0.0191313185456315 5.78940488087729e-07" rpy="0.0 -0.0 0.0"/>
        <mass value="0.0612328998065947"/>
        <inertia ixx="1.33040989290318e-05" ixy="2.5040849060523e-07" ixz="4.80025662292933e-09" iyy="1.27387024978889e-05" iyz="-4.2924245435293e-09" izz="1.50538962870715e-05"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://${package_name}/urdf/grape/meshes/arm/screw_hinge_module_dynamixel/link1.dae"/>
        </geometry>
        <material name="${prefix}__unnamed_material_2"/>
        <origin xyz="2.09657352239695e-18 -0.035 1.00064680020069e-17" rpy="3.141592653589793 1.570796326794893 3.141592653589793"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://${package_name}/urdf/grape/meshes/arm/screw_hinge_module_dynamixel/link1.stl"/>
        </geometry>
        <origin xyz="2.09657352239695e-18 -0.035 1.00064680020069e-17" rpy="3.141592653589793 1.570796326794893 3.141592653589793"/>
      </collision>
    </link>
    <link name="${prefix}dummy_link"/>
    <joint name="${prefix}joint1" type="revolute">
      <limit effort="0.0" velocity="0.0" lower="-0.567" upper="0.567"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link1"/>
      <axis xyz="-1.  0.  0."/>
      <origin xyz="0.0 0.0 0.035" rpy="1.5708 -0.0 3.1415853071795867"/>
    </joint>
    <joint name="${prefix}dummy_joint" type="fixed">
      <limit effort="0.0" velocity="0.0"/>
      <parent link="${prefix}link1"/>
      <child link="${prefix}dummy_link"/>
      <axis xyz="0. 0. 0."/>
      <origin xyz="0.0 0.045 0.0" rpy="-1.5707926535897931 -1.5707926535897934 3.141592653589793"/>
    </joint>
    <material name="${prefix}__unnamed_material_1">
      <color rgba="0.29803922 0.29803922 0.29803922 1.        "/>
    </material>
    <material name="${prefix}__unnamed_material_2">
      <color rgba="0.75294118 0.75294118 0.75294118 1.        "/>
    </material>
  </xacro:macro>
</robot>
