  <joint name="gimbal1" type="revolute">
    <limit effort="5.0" velocity="10.0" lower="-3.14" upper="3.14"/>
    <parent link="main_body"/>
    <child link="gimbal1_link"/>
    <axis xyz="1. 0. 0."/>
    <origin xyz="-0.22309 -0.22309 0.0" rpy="0.0 -0.0 -2.3562"/>
  </joint>

  <joint name="rotor1" type="continuous">
    <limit effort="0.0" velocity="0.0" lower="0.0" upper="30.0"/>
    <parent link="gimbal1_link"/>
    <child link="thrust1"/>
    <axis xyz=" 0.  0. -1."/>
    <origin xyz="0.0 0.0 0.0585" rpy="0.0 -0.0 0.0"/>
  </joint>

  <joint name="gimbal2" type="revolute">
