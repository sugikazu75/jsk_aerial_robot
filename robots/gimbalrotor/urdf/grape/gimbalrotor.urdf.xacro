  </link>
  <link name="rotor_arm3">
    <xacro:virtual_inertial/>
  </link>
  <link name="rotor_arm4">
    <xacro:virtual_inertial/>
  </link>

  <joint name="rotor_arm1_joint" type="fixed">
    <parent link="main_body"/>
    <child link="rotor_arm1"/>
    <axis xyz="0 0 1"/>
    <origin xyz="-0.22309 -0.22309 0.0" rpy="0.0 -0.0 -2.3562"/>
  </joint>
  <joint name="rotor_arm2_joint" type="fixed">
    <parent link="main_body"/>
    <child link="rotor_arm2"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0.22309 -0.22309 0.0" rpy="-0.0 -0.0 -0.7854000000000001"/>
  </joint>
  <joint name="rotor_arm3_joint" type="fixed">
    <parent link="main_body"/>
    <child link="rotor_arm3"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0.22309 0.22309 0.0" rpy="0.0 -0.0 0.7854000000000001"/>
  </joint>
  <joint name="rotor_arm4_joint" type="fixed">
    <parent link="main_body"/>
    <child link="rotor_arm4"/>
    <axis xyz="0 0 1"/>
    <origin xyz="-0.22309 0.22309 0.0" rpy="0.0 -0.0 2.3562"/>
  </joint>

  <joint name="gimbal1" type="revolute">
    <limit effort="5.0" velocity="10.0" lower="-3.14" upper="3.14"/>
    <parent link="main_body"/>
    <child link="gimbal1_link"/>
    <axis xyz="1. 0. 0."/>
    <origin xyz="-0.22309 -0.22309 0.0" rpy="0.0 -0.0 -2.3562"/>
  </joint>

  <joint name="rotor1" type="continuous">
    <limit effort="0.0" velocity="0.0" lower="0.0" upper="30.0"/>
    <parent link="gimbal1_link"/>
    <child link="thrust1"/>
    <axis xyz=" 0.  0. -1."/>
    <origin xyz="0.0 0.0 0.0585" rpy="0.0 -0.0 0.0"/>
  </joint>

  <joint name="gimbal2" type="revolute">
    <limit effort="5.0" velocity="10.0" lower="-3.14" upper="3.14"/>
    <parent link="main_body"/>
    <child link="gimbal2_link"/>
    <axis xyz="1. 0. 0."/>
    <origin xyz="0.22309 -0.22309 0.0" rpy="-0.0 -0.0 -0.7854000000000001"/>
  </joint>

  <joint name="rotor2" type="continuous">
    <limit effort="0.0" velocity="0.0" lower="0.0" upper="30.0"/>
    <parent link="gimbal2_link"/>
    <child link="thrust2"/>
    <axis xyz="0. 0. 1."/>
    <origin xyz="0.0 0.0 0.0585" rpy="0.0 -0.0 0.0"/>
  </joint>

  <joint name="gimbal3" type="revolute">
    <limit effort="5.0" velocity="10.0" lower="-3.14" upper="3.14"/>
    <parent link="main_body"/>
    <child link="gimbal3_link"/>
    <axis xyz="1. 0. 0."/>
    <origin xyz="0.22309 0.22309 0.0" rpy="0.0 -0.0 0.7854000000000001"/>
  </joint>

  <joint name="rotor3" type="continuous">
    <limit effort="0.0" velocity="0.0" lower="0.0" upper="30.0"/>
    <parent link="gimbal3_link"/>
    <child link="thrust3"/>
    <axis xyz=" 0.  0. -1."/>
    <origin xyz="0.0 0.0 0.0585" rpy="0.0 -0.0 0.0"/>
  </joint>

  <joint name="gimbal4" type="revolute">
    <limit effort="5.0" velocity="10.0" lower="-3.14" upper="3.14"/>
    <parent link="main_body"/>
    <child link="gimbal4_link"/>
    <axis xyz="1. 0. 0."/>
    <origin xyz="-0.22309 0.22309 0.0" rpy="0.0 -0.0 2.3562"/>
  </joint>

  <joint name="rotor4" type="continuous">
    <limit effort="0.0" velocity="0.0" lower="0.0" upper="30.0"/>
    <parent link="gimbal4_link"/>
    <child link="thrust4"/>
    <axis xyz="0. 0. 1."/>
    <origin xyz="0.0 0.0 0.0585" rpy="0.0 -0.0 0.0"/>
  </joint>


  <transmission name="gimbal1_tran">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="gimbal1">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="servo1">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

